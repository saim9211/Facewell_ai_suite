<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reportRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/bg_home_header_round"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/back_arrow"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvReportTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Eye Report"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="20sp" />
        </FrameLayout>

        <!-- Scroll Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Main Preview -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="360dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"
                    android:layout_marginHorizontal="2dp">

                    <ImageView
                        android:id="@+id/ivPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Result Header Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <View
                        android:layout_width="4dp"
                        android:layout_height="24dp"
                        android:background="@color/teal_bg" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:id="@+id/tvSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Analysis Summary"
                            android:textSize="14sp"
                            android:textColor="@color/text_muted"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvOverallResult"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OVERALL RESULT"
                            android:textColor="@color/teal_bg"
                            android:textStyle="bold"
                            android:textSize="18sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="12dp" />

                <!-- Eye Results -->
                <LinearLayout
                    android:id="@+id/container_eye"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:id="@+id/rowFindings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="10">

                        <!-- Left Eye -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardLeft"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="5"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#F0F0F0"
                            android:layout_marginEnd="6dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/ivLeftCrop"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"
                                    android:scaleType="centerCrop" />

                                <TextView
                                    android:id="@+id/tvLeftLabel"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:background="@color/white" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Right Eye -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardRight"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="5"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#F0F0F0"
                            android:layout_marginStart="6dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/ivRightCrop"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"
                                    android:scaleType="centerCrop" />

                                <TextView
                                    android:id="@+id/tvRightLabel"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:background="@color/white" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="16dp" />

                    <TextView
                        android:id="@+id/tvAccuracyLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Accuracy Level: 82%"
                        android:textStyle="bold"
                        android:textColor="@color/black" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="12dp" />

                    <!-- Recommendations -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardRecommendations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="20dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#F0F0F0"
                        app:cardElevation="2dp"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/input_fill"
                        android:layout_marginHorizontal="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/tvRecTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Recommended organic care"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="@color/teal_bg" />

                            <TextView
                                android:id="@+id/tvRecSummary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp"
                                android:layout_marginTop="8dp" />

                            <LinearLayout
                                android:id="@+id/llTips"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginTop="12dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvProductsTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Recommended Products"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/black" />

                    <!-- FINAL PRODUCT LIST (VERTICAL) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvProducts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSeeMoreProducts"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="See More Products"
                        android:textColor="@color/teal_bg"
                        android:backgroundTint="@android:color/white"
                        app:cornerRadius="16dp"
                        app:strokeColor="@color/teal_bg"
                        app:strokeWidth="2dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="16dp"
                        android:textStyle="bold" />

                    <!-- Action Buttons Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveReport"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="54dp"
                            android:text="Save Report"
                            android:textColor="@android:color/white"
                            app:backgroundTint="@color/teal_bg"
                            app:cornerRadius="16dp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnVisitClinic"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="54dp"
                            android:layout_marginStart="12dp"
                            android:text="Visit Clinic"
                            android:textColor="@android:color/white"
                            app:backgroundTint="@color/teal_bg"
                            app:cornerRadius="16dp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGoHome"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="Go Home"
                        android:textColor="@color/teal_bg"
                        android:backgroundTint="@android:color/white"
                        app:cornerRadius="16dp"
                        app:strokeColor="@color/teal_bg"
                        app:strokeWidth="2dp"
                        android:layout_marginBottom="24dp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDisclaimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Disclaimer: These are suggestions, not medical advice."
                        android:textSize="12sp"
                        android:textColor="@color/text_muted" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
