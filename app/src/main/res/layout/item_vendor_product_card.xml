<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProduct"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:strokeWidth="0dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="16dp"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- IMAGE -->
        <ImageView
            android:id="@+id/imgProduct"
            android:layout_width="115dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:src="@drawable/img_product_placeholder"
            android:background="@drawable/rounded_image_bg"
            android:layout_marginEnd="12dp"/>

        <!-- RIGHT SIDE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- TITLE -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Title"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <!-- DESCRIPTION -->
            <TextView
                android:id="@+id/tvDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Short description"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:layout_marginTop="3dp"/>

            <!-- ⭐ RATING ROW -->
            <LinearLayout
                android:id="@+id/ratingRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvStar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:id="@+id/tvRatingCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(0)"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- ROW 1: CATEGORY + PRICE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="eye"
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:background="@drawable/badge_bg"/>

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PKR 0"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- ROW 2: EDIT + DELETE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start"
                android:layout_marginTop="6dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditProduct"
                    android:layout_width="72dp"
                    android:layout_height="36dp"
                    android:text="Edit"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:backgroundTint="@color/teal_light"
                    app:cornerRadius="20dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/teal_mid"
                    android:textColor="@color/teal_mid"/>

                <ImageView
                    android:id="@+id/btnDelete"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:elevation="2dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_delete"
                    android:background="@drawable/bg_delete_circle"
                    android:scaleType="centerInside"
                    android:contentDescription="delete"
                    app:tint="@color/logout_red"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
