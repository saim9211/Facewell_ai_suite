<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:padding="12dp"
    app:cardElevation="3dp"
    app:cardCornerRadius="16dp"
    android:backgroundTint="@color/white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- NAME -->
        <TextView
            android:id="@+id/tvClinicName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clinic Name"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <!-- SPECIALIST / TYPE -->
        <TextView
            android:id="@+id/tvClinicSpecialist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Specialist info"
            android:textColor="@color/text_muted"
            android:textSize="13sp"/>

        <!-- PHONE + CALL ICON ROW -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvClinicPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+92 300 0000000"
                android:textColor="@color/teal_bg"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="4dp"/>

            <ImageButton
                android:id="@+id/btnCall"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_phone"
                app:tint="@color/teal_bg"
                android:background="@android:color/transparent"
                android:contentDescription="Call clinic"/>
        </LinearLayout>

        <!-- ADDRESS + META (distance, ETA) -->
        <TextView
            android:id="@+id/tvClinicMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2.5 km • ETA: 10 min"
            android:layout_marginTop="6dp"
            android:textColor="@color/text_muted"
            android:textSize="13sp"/>

        <!-- MAP BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenMaps"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:text="Open in Google Maps"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:backgroundTint="@color/teal_bg"
            app:cornerRadius="16dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
