<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollClinicProfile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="90dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header : rounded teal background (use your bg_home_header_round drawable) -->
        <FrameLayout
            android:id="@+id/headerClinic"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_home_header_round"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvClinicProfileTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clinic profile"
                    android:textColor="@color/on_teal"
                    android:textSize="20sp"
                    android:textStyle="bold" />

<!--                <TextView-->
<!--                    android:id="@+id/tvClinicProfileSub"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:layout_marginTop="6dp"-->
<!--                    android:text="Overview and contact"-->
<!--                    android:textColor="@color/on_teal"-->
<!--                    android:textSize="14sp" />-->
            </LinearLayout>

            <!-- Edit button top-right inside header -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditClinicProfile"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="25dp"
                android:layout_marginEnd="12dp"
                android:text="Edit"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/teal_bg"
                app:backgroundTint="@color/white"
                app:cornerRadius="18dp"
                android:elevation="0dp"/>

        </FrameLayout>

        <!-- Details card like user profile -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardClinicDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/input_fill"
            app:useCompatPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textColor="@color/text_muted"/>
                <TextView
                    android:id="@+id/tvClinicName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="16sp"/>

                <View android:layout_width="match_parent" android:layout_height="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="@color/text_muted"/>
                <TextView
                    android:id="@+id/tvClinicEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"/>

                <View android:layout_width="match_parent" android:layout_height="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone"
                    android:textColor="@color/text_muted"/>
                <TextView
                    android:id="@+id/tvClinicPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="16sp"/>

                <View android:layout_width="match_parent" android:layout_height="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="City"
                    android:textColor="@color/text_muted"/>
                <TextView
                    android:id="@+id/tvClinicCity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="16sp"/>

                <View android:layout_width="match_parent" android:layout_height="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Address"
                    android:textColor="@color/text_muted"/>
                <TextView
                    android:id="@+id/tvClinicAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="16sp"/>

                <View android:layout_width="match_parent" android:layout_height="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Website"
                    android:textColor="@color/text_muted"/>
                <TextView
                    android:id="@+id/tvClinicWebsite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Logout row -->
        <LinearLayout
            android:id="@+id/listOptionsClinic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/rowLogoutClinic"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/input_fill"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:id="@+id/tvLogoutClinic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Logout"
                        android:textColor="@color/logout_red"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
