<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- PAGE TITLE -->
        <TextView
            android:id="@+id/tvHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clinics"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/teal_bg"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- TAB SELECTORS -->
        <LinearLayout
            android:id="@+id/tabsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegistered"
                android:text="Registered"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="42dp"
                android:textAllCaps="false"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="12dp"
                android:backgroundTint="@color/teal_light"
                app:strokeColor="@color/teal_bg"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNearby"
                android:text="Nearby"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="42dp"
                android:textAllCaps="false"
                android:layout_marginStart="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="12dp"
                app:strokeColor="@color/teal_bg"/>
        </LinearLayout>

        <!-- Registered Clinics Recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRegistered"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:padding="16dp"
            android:paddingBottom="50dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/tabsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Nearby Clinics Recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNearby"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:padding="16dp"
            android:paddingBottom="50dp"
            android:clipToPadding="false"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tabsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- EMPTY TEXT -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No clinics found"
            android:textColor="@color/text_muted"
            android:textSize="16sp"
            android:visibility="gone"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toBottomOf="@id/tabsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
